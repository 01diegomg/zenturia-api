# ===========================================
# ZENTURIA - Barber Core API
# Variables de Entorno
# ===========================================
# Copia este archivo a .env y llena los valores
# NUNCA subas .env al repositorio!

# Server Configuration
NODE_ENV=development
PORT=3000

# ===========================================
# DATABASE (PostgreSQL para Railway)
# ===========================================
# Railway proporciona esta URL automaticamente como variable
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/barberia?schema=public"

# ===========================================
# JWT Secrets (CAMBIAR EN PRODUCCION!)
# ===========================================
# Genera claves seguras con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu-clave-secreta-jwt-cambiar-en-produccion
JWT_REFRESH_SECRET=tu-clave-secreta-refresh-cambiar-en-produccion

# ===========================================
# CORS - Origenes Permitidos
# ===========================================
# Separados por coma. En Railway seria tu dominio
# La app movil no necesita estar aqui (no envia Origin header)
# Ejemplo: https://zenturia.railway.app,https://tudominio.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ===========================================
# CLOUDINARY (Servicio Externo - Imagenes)
# ===========================================
# Obtener de: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ===========================================
# EMAIL (SendGrid - Opcional)
# ===========================================
SENDGRID_API_KEY=tu-sendgrid-api-key
ADMIN_EMAIL=admin@tudominio.com
SENDER_EMAIL=noreply@tudominio.com

# ===========================================
# CONFIGURACION EN RAILWAY:
# ===========================================
# 1. DATABASE_URL -> Railway la genera automaticamente al agregar PostgreSQL
# 2. NODE_ENV -> production
# 3. JWT_SECRET -> Genera una clave segura
# 4. JWT_REFRESH_SECRET -> Genera otra clave segura
# 5. CLOUDINARY_* -> Tus credenciales de Cloudinary
# 6. ALLOWED_ORIGINS -> https://tu-app.railway.app

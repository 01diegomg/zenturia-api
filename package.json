{
  "name": "barber-backend",
  "version": "2.0.0",
  "description": "Barber Studio Cruzito - Production Ready",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "build": "npx prisma generate && npx prisma db push",
    "postinstall": "npx prisma generate",
    "start:backend": "nodemon server.js",
    "start:frontend": "live-server public",
    "watch:css": "node ./node_modules/tailwindcss/lib/cli.js -i ./public/src/input.css -o ./public/Barber_Fusion.css --watch",
    "dev": "concurrently \"npm:start:backend\" \"npm:start:frontend\" \"npm:watch:css\"",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio"
  },
  "keywords": ["barber", "booking", "appointments"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.0.0",
    "express-slow-down": "^2.0.0",
    "express-validator": "^7.2.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "nodemailer-sendgrid-transport": "^0.2.0",
    "prisma": "^5.13.0",
    "sanitize-html": "^2.11.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.11.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
